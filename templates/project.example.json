{
  "project_name": "example_project",
  "target": "../data/target.fa",
  "output_dir": "../results/example_project",
  "input": {
    "r1": "../data/raw/mixed_R1.fastq.gz",
    "r2": "../data/raw/mixed_R2.fastq.gz"
  },
  "demux": {
    "search_bases": 40,
    "max_mismatches": 1,
    "anchored": false,
    "match_mode": "any",
    "check_reverse_complement": false,
    "samples": [
      {
        "group": "RNA1",
        "name": "plus_modified",
        "role": "modified",
        "r1_primers": ["ACGTACGTACGT"],
        "r2_primers": []
      },
      {
        "group": "RNA1",
        "name": "minus_untreated",
        "role": "untreated",
        "r1_primers": ["TGCATGCATGCA"],
        "r2_primers": []
      },
      {
        "group": "RNA1",
        "name": "denatured_control",
        "role": "denatured",
        "r1_primers": ["GATTACAGATTA"],
        "r2_primers": []
      },
      {
        "group": "RNA2",
        "name": "rna2_modified",
        "role": "modified",
        "r1_primers": ["TAGCTTGT"],
        "r2_primers": []
      },
      {
        "group": "RNA2",
        "name": "rna2_untreated",
        "role": "untreated",
        "r1_primers": ["ATCACGTT"],
        "r2_primers": []
      }
    ]
  },
  "shapemapper": {
    "executable": "~/tools/shapemapper2-2.3/shapemapper",
    "amplicon": true,
    "nproc": 4,
    "min_depth": 1000,
    "min_mapq": 10,
    "min_qual_to_trim": 20,
    "window_to_trim": 5,
    "min_qual_to_count": 30,
    "max_bg": 0.05,
    "max_paired_fragment_length": 800
  }
}
